# Directory where yield studies will be saved to
STUDY_DIR="/home/rohan/Downloads/demo"
# Directory where to cache CHIRPS data
CHIRPS_DIR="/home/rohan/Downloads/demo/chirps"
# Directory where to cache NASAPower data
NP_CACHE_DIR="/abcd/"
# Directory where to cache ERA5 Met data
ERA5_CACHE_DIR="/acbde/"
# Directory where to save generated LAI products
LAI_BASE_DIR="/path/to/lai/storage"
# Directory where to save cropmasks
CROPMASKS_BASE_DIR="/path/to/cropmasks/storage"
# Path to dotnet root dir to set this as an env variable for running DOTNET programs (APSIM)
DOTNET_ROOT_PATH="/path/to/dotnet"
# Path to apsim installation Models (File is called Models in the binary compiled output)
APSIM_PATH="/path/to/apsim/bin/Models"
# Path to the private matching script. Implementation may only be shared on request by authors
MATCHING_SCRIPT_PATH="/path/to/match_sim_real.py"
# Google Earth Engine project name. Needed if using ERA5 meteorological data
EE_PROJECT_NAME="my-ee-projectname"
# PATH to a Google Earth Engine service account key (JSON). If set, this is used instead of user credentials for EE authentication.
EE_SERVICE_ACCOUNT_KEY=""

# --- Results upload (optional, via rclone) ---
# Destination for the packaged final results zip. Must be a configured
# rclone remote, e.g. 'gdrive:' or 'gdrive:vercye_kenya'. Run `rclone config`
# once to set the remote up. Leave empty to skip the upload step.
RCLONE_TARGET=""
# Optional subfolder under RCLONE_TARGET that all uploads are grouped under.
RCLONE_FOLDER_PREFIX=""

# --- Webapp-specific settings - only requed only if using the webapp (vercye_webapp/run.sh) ---
# Path to conda/venv bin directory. If set, PYTHONNOUSERSITE=1 will also be exported to isolate the env.
# PYTHON_ENV_PATH="/home/user/conda-env/bin"
# Optional: Override cache directory (e.g. for redirect to GPFS to avoid filling home)
# XDG_CACHE_HOME="/gpfs/data1/project/.cache"
# Path to NVM installation directory (for building the frontend with npm)
# NVM_DIR="/path/to/.nvm"
# Path to redis-server binary
# REDIS_PATH="/usr/bin/redis-server"
# Directory for log files (defaults to ./logs)
# LOGS_PATH="./logs"
# Unix socket path for Uvicorn (defaults to /tmp/vercye-uvicorn.sock)
# SOCKET_PATH="/tmp/vercye-uvicorn.sock"
# Comma-separated list of users to grant socket access via ACL
# USERS="user1,user2"
